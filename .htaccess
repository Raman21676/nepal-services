# ============================================
# NEPAL SERVICES DIRECTORY - SECURITY CONFIG
# Comprehensive protection against data theft
# ============================================

# Disable directory browsing
Options -Indexes

# Protect sensitive files
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block access to sensitive directories
RedirectMatch 403 /\.git/.*$
RedirectMatch 403 /\.env.*$
RedirectMatch 403 /node_modules/.*$
RedirectMatch 403 /data/.*$

# Protect data files - only allow internal JS access
<FilesMatch "\.(json|csv|xml|sql|db|sqlite)$">
    Order deny,allow
    Deny from all
    # Allow same-origin requests only
    <IfModule mod_headers.c>
        Header set Access-Control-Allow-Origin "https://nepalservice.online"
        Header set Access-Control-Allow-Methods "GET"
    </IfModule>
</FilesMatch>

# Rate limiting - block rapid requests
<IfModule mod_evasive.c>
    DOSHashTableSize 3097
    DOSPageCount 2
    DOSSiteCount 50
    DOSPageInterval 1
    DOSSiteInterval 1
    DOSBlockingPeriod 600
</IfModule>

# Block common scraping user agents
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Block known scrapers
    RewriteCond %{HTTP_USER_AGENT} (scrapy|curl|wget|python|java|php|ruby|perl|libwww|httpclient|scraping|bot|spider|crawler) [NC]
    RewriteRule ^ - [F,L]
    
    # Block empty user agents
    RewriteCond %{HTTP_USER_AGENT} ^$
    RewriteRule ^ - [F,L]
    
    # Block suspicious headers
    RewriteCond %{HTTP:Accept} ^$
    RewriteRule ^ - [F,L]
    
    # Block multiple rapid requests from same IP
    RewriteCond %{REMOTE_ADDR} ^(.*)$
    RewriteCond %{HTTP_COOKIE} !^.*antiscraping=.*$
    RewriteRule ^ - [CO=antiscraping:1:%{REMOTE_ADDR}:600:/,L]
</IfModule>

# Enable browser caching for static assets (reduces server load)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
</IfModule>

# Prevent image hotlinking (data theft via direct linking)
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTP_REFERER} !^$
    RewriteCond %{HTTP_REFERER} !^https?://(www\.)?nepalservice\.online [NC]
    RewriteRule \.(jpg|jpeg|png|gif|svg)$ - [NC,F,L]
</IfModule>

# Security headers
<IfModule mod_headers.c>
    # Prevent MIME type sniffing
    Header set X-Content-Type-Options "nosniff"
    
    # Prevent clickjacking
    Header set X-Frame-Options "SAMEORIGIN"
    
    # XSS Protection
    Header set X-XSS-Protection "1; mode=block"
    
    # Referrer Policy
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Remove server identification
    Header unset X-Powered-By
    Header unset Server
    
    # Disable content sniffing
    Header set X-Content-Type-Options nosniff
    
    # Enforce HTTPS
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
</IfModule>

# Disable server signature
ServerSignature Off

# Limit request body size (prevent DOS)
LimitRequestBody 10485760

# PHP settings (if PHP is used)
<IfModule mod_php.c>
    php_flag display_errors off
    php_flag expose_php off
    php_flag allow_url_fopen off
    php_flag allow_url_include off
</IfModule>

# Block specific IPs (add scraper IPs here)
<RequireAll>
    Require all granted
    # Example: Require not ip 192.168.1.100
</RequireAll>

# ============================================
# END SECURITY CONFIGURATION
# ============================================
